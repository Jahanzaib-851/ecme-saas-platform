# ═══════════════════════════════════════════════════════════════════════════════
#  ECME Backend — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production

# The frontend origin allowed by CORS.
# In production use your Vercel URL. Comma-separate for multiple origins.
# e.g. FRONTEND_URL=https://ecme-saas-platform.vercel.app,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Get your connection string from MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
# Use a random string of at least 64 characters in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING

# ─── Email / SMTP (required for OTP emails in production) ────────────────────
# In development the OTP is returned in the API response — no SMTP needed.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false               # true for port 465
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password     # Gmail: use App Password, not account password
# SMTP_FROM="ECME App <noreply@yourapp.com>"

# ─── Firebase Admin SDK (required for Google Sign-In) ────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Download the JSON file and copy values from it:
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private_key value exactly. Render/Vercel handle \n literally — use \\n:
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
